[Unit]
Description=salyut.one BBS daemon
After=local-fs.target
RequiresMountsFor=/var/lib/salyut-bbs

[Service]
Type=simple
User=salyut-bbsd
Group=salyut-bbs
ExecStart=/usr/local/bin/salyut-bbsd
Restart=on-failure
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/salyut-bbs /var/lib/salyut-bbs

[Install]
WantedBy=multi-user.target
